MIRTH_BASE_URL=https://localhost:8443
MIRTH_USERNAME=admin
MIRTH_PASSWORD=admin

# true when cert is valid; false for local self-signed certs
MIRTH_VERIFY_TLS=false

# dev | test | prod
MIRTH_ENV=dev

# Full access switch
MIRTH_FULL_ACCESS=true

# Allows destructive operations: delete channel, remove messages, clear stats, redeploy all
MIRTH_ALLOW_DESTRUCTIVE=true

# Allows write operations in production.
MIRTH_ALLOW_PROD_WRITE=false

# Enables mccommand fallback when REST API is unavailable.
MIRTH_ENABLE_CLI_FALLBACK=true
MIRTH_CLI_PATH=/opt/mirthconnect/mccommand

# Local artifact paths
MIRTH_BACKUP_DIR=backups
MIRTH_LOG_DIR=logs
MIRTH_ACTOR=ai_mirth_agent
MIRTH_TIMEOUT=30
